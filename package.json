{
  "name": "infinity-broadcast-scheduler",
  "version": "0.1.0",
  "description": "Cron quotidien qui génère les broadcasts radio pré-enregistrés pour Infinity (1 broadcast par station seed par jour, publié sur IPFS+NOSTR). Tourne en GitHub Actions.",
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "generate:one":  "tsx src/scripts/generate-broadcast.ts",
    "generate:all":  "tsx src/scripts/generate-all.ts",
    "typecheck":     "tsc --noEmit",
    "setup:piper":   "tsx src/scripts/setup-piper.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@noble/hashes":     "^1.5.0",
    "dotenv":            "^16.4.5",
    "fast-xml-parser":   "^4.5.0",
    "nostr-tools":       "^2.10.4",
    "tsx":               "^4.19.2",
    "typescript":        "^5.6.3"
  },
  "devDependencies": {
    "@types/node":       "^22.7.5"
  },
  "engines": {
    "node": ">=20"
  }
}
