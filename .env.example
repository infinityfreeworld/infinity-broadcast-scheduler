# Anthropic API key — utilisée pour générer les dialogues IA (Haiku 4.5)
# Coût estimé : ~$0.04 par broadcast × 9 stations / jour = ~$0.36/jour = ~$11/mois
ANTHROPIC_API_KEY=sk-ant-...

# Pinata JWT — utilisé pour upload IPFS (free tier 1 GB)
# https://app.pinata.cloud/developers/api-keys
PINATA_JWT=eyJhbGciOiJIUzI1NiIs...

# NOSTR private key (hex) — identité du publisher des broadcasts (kind:30093)
# Génère avec: openssl rand -hex 32
NOSTR_PRIVATE_KEY=abc123...

# Modèle Anthropic (défaut: claude-haiku-4-5-20251001 — économique)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Nombre de tours par broadcast (défaut: 25)
NUM_TURNS=25

# Date cible YYYY-MM-DD (défaut: J+1 = lendemain). Override pour rattrapage.
# TARGET_DATE=2026-05-06

# ── Sprint DE — Chatterbox TTS (optionnel, hybride avec Piper) ────────
# Si CHATTERBOX_TTS_URL est défini ET un host est mappé dans
# CHATTERBOX_VOICE_MAP (ou CHATTERBOX_DEFAULT_VOICE), la synthèse passe
# par Chatterbox. Sinon ou si Chatterbox fail, fallback Piper FR auto.
#
# HF Space déployé séparément (image ghcr.io/devnen/chatterbox-tts-server)
# CHATTERBOX_TTS_URL=https://username-chatterbox-nestor.hf.space
# CHATTERBOX_API_KEY=hf_...
#
# Voix par host (JSON) — clé = hostId, valeur = voice name côté Space
# CHATTERBOX_VOICE_MAP={"wtf-cyril":"cyril-fr","wtf-marina":"marina-fr"}
#
# Voix par défaut si aucun mapping ne match (toutes voix sur Chatterbox)
# CHATTERBOX_DEFAULT_VOICE=nestor
#
# Langue par défaut (multilingual model) — défaut 'fr'
# CHATTERBOX_LANGUAGE=fr
#
# Fallback automatique sur Piper si Chatterbox fail — défaut 'true'
# Mettre 'false' pour échouer dur (utile en debug).
# CHATTERBOX_FALLBACK_PIPER=true
